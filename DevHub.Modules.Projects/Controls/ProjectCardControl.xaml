<UserControl x:Class="DevHub.Modules.Projects.Controls.ProjectCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DevHub.Infrastructure.Converters;assembly=DevHub.Infrastructure">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
    </UserControl.Resources>

    <Border Padding="16" 
            CornerRadius="12" 
            BorderBrush="#3A3A3A" 
            BorderThickness="1" 
            RenderTransformOrigin="0.5,0.5">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#5A9FFF"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#5A9FFF" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid RowDefinitions="Auto,*,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" 
                           Text="{Binding Name}" 
                           FontWeight="SemiBold" 
                           FontSize="16" 
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding ShowName, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Border Grid.Column="1" 
                        HorizontalAlignment="Right" 
                        Style="{StaticResource NeonBadge}"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowLanguage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding Language}" 
                               FontSize="11" 
                               FontWeight="SemiBold"
                               Foreground="#7FC8F8"/>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12"
                  Visibility="{Binding ShowDescription, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding Description}" 
                           TextWrapping="Wrap" 
                           FontSize="12" 
                           Foreground="#B0B0B0"
                           LineHeight="18"
                           MaxHeight="54"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <Grid Grid.Row="2" Cursor="">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="1" HorizontalAlignment="Right"
                            Command="{Binding OpenFolderCommand}" 
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Открыть папку проекта"
                            Width="32" 
                            Height="32"
                            Padding="4"
                            VerticalAlignment="Bottom">
                        <TextBlock Text="📁" FontSize="16"/>
                    </Button>
                    <TextBlock Grid.Column="2" 
                               Text="{Binding LastModified, StringFormat={}{0:dd.MM.yyyy}}" 
                               FontSize="10" 
                               Foreground="#808080"
                               VerticalAlignment="Center"
                               Visibility="{Binding ShowLastModified, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <ItemsControl ItemsSource="{Binding IDEs}"
                                  Visibility="{Binding ShowIDEButtons, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenInIDECommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="{Binding Name}"
                                        Width="32"
                                        Height="32"
                                        Padding="4"
                                        Margin="1">
                                    <Image Source="{Binding IconPath}" 
                                           Stretch="Uniform" 
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
