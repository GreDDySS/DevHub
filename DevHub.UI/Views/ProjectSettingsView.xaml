<UserControl x:Class="DevHub.UI.Views.ProjectSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DevHub.Core.Models;assembly=DevHub.Core">
    <UserControl.Resources>
        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок удаления -->
        <Style x:Key="RemoveButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#4A1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Стиль для TextBox -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
        </Style>

        <!-- Стиль для CheckBox -->
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" MaxHeight="650">
        <StackPanel Margin="0,0,0,20">
            <!-- Заголовок -->
            <TextBlock Text="Настройки проектов" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#FFFFFF" 
                       Margin="0,0,0,20"/>

            <!-- Функциональные настройки -->
            <TextBlock Text="Функциональные настройки" Style="{StaticResource SectionHeader}"/>

            <!-- Пути сканирования -->
            <Border Background="#252526" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Пути сканирования" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#E0E0E0" 
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding ScanPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding Path=., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource SettingsTextBox}"/>
                                    <Button Grid.Column="1" 
                                            Content="✕" 
                                            Style="{StaticResource RemoveButton}"
                                            Command="{Binding DataContext.RemoveScanPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Добавить путь" 
                            Command="{Binding AddScanPathCommand}"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Left"
                            Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Расширения файлов -->
            <Border Background="#252526" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Расширения файлов" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#E0E0E0" 
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding FileExtensions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding Path=., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource SettingsTextBox}"/>
                                    <Button Grid.Column="1" 
                                            Content="✕" 
                                            Style="{StaticResource RemoveButton}"
                                            Command="{Binding DataContext.RemoveFileExtensionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Добавить расширение" 
                            Command="{Binding AddFileExtensionCommand}"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Left"
                            Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Частота обновления -->
            <Border Background="#252526" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Частота обновления (минут)" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#E0E0E0" 
                               Margin="0,0,0,10"/>
                    <TextBox Text="{Binding RefreshIntervalMinutes, Mode=TwoWay}" 
                             Style="{StaticResource SettingsTextBox}"
                             Width="150"
                             HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- IDE -->
            <Border Background="#252526" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="IDE" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#E0E0E0" 
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding IDEs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:IDEInfo}">
                                <Border Background="#1E1E1E" 
                                        Padding="10" 
                                        CornerRadius="6" 
                                        Margin="0,0,0,10"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                                   Text="Название:" 
                                                   Foreground="#B0B0B0" 
                                                   Margin="0,0,0,5"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" 
                                                 Text="{Binding Name, Mode=TwoWay}" 
                                                 Style="{StaticResource SettingsTextBox}"
                                                 Width="200"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                                   Text="Путь к исполняемому файлу:" 
                                                   Foreground="#B0B0B0" 
                                                   Margin="0,5,0,5"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" 
                                                 Text="{Binding ExecutablePath, Mode=TwoWay}" 
                                                 Style="{StaticResource SettingsTextBox}"
                                                 Width="200"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                                   Text="Аргументы:" 
                                                   Foreground="#B0B0B0" 
                                                   Margin="0,5,0,5"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" 
                                                 Text="{Binding Arguments, Mode=TwoWay}" 
                                                 Style="{StaticResource SettingsTextBox}"
                                                 Width="200"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                                   Text="Путь к иконке:" 
                                                   Foreground="#B0B0B0" 
                                                   Margin="0,5,0,0"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" 
                                                 Text="{Binding IconPath, Mode=TwoWay}" 
                                                 Style="{StaticResource SettingsTextBox}"
                                                 Width="200"/>

                                        <Button Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Content="✕" 
                                                Style="{StaticResource RemoveButton}"
                                                Command="{Binding DataContext.RemoveIDECommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,-30,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Добавить IDE" 
                            Command="{Binding AddIDECommand}"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Left"
                            Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Визуальные настройки -->
            <TextBlock Text="Визуальные настройки" 
                       Style="{StaticResource SectionHeader}" 
                       Margin="0,10,0,0"/>

            <Border Background="#252526" Padding="15" CornerRadius="8">
                <StackPanel>
                    <CheckBox Content="Показывать название проекта" 
                              IsChecked="{Binding ShowName, Mode=TwoWay}"
                              Style="{StaticResource SettingsCheckBox}"/>
                    <CheckBox Content="Показывать описание" 
                              IsChecked="{Binding ShowDescription, Mode=TwoWay}"
                              Style="{StaticResource SettingsCheckBox}"/>
                    <CheckBox Content="Показывать язык" 
                              IsChecked="{Binding ShowLanguage, Mode=TwoWay}"
                              Style="{StaticResource SettingsCheckBox}"/>
                    <CheckBox Content="Показывать дату изменения" 
                              IsChecked="{Binding ShowLastModified, Mode=TwoWay}"
                              Style="{StaticResource SettingsCheckBox}"/>
                    <CheckBox Content="Показывать кнопки IDE" 
                              IsChecked="{Binding ShowIDEButtons, Mode=TwoWay}"
                              Style="{StaticResource SettingsCheckBox}"/>
                </StackPanel>
            </Border>

            <!-- Кнопки действий -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="Отмена" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="#3A3A3A"/>
                <Button Content="Сохранить" 
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="#2A5A7A"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>