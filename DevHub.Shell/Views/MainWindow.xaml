<Window x:Class="DevHub.Shell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DevHub.Shell.Views"
        xmlns:modules="clr-namespace:DevHub.Modules.Projects.Views;assembly=DevHub.Modules.Projects"
        xmlns:converters="clr-namespace:DevHub.Infrastructure.Converters;assembly=DevHub.Infrastructure"
        Title="DevHub" 
        Height="1000" Width="650">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" Padding="10">
            <StackPanel>
                <TextBlock Text="DevHub" Foreground="white" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button Content="Проекты" Height="40" Margin="0,0,0,8"/>
                <Button Content="Ссылки" Height="40" Margin="0,0,0,8"/>
                <Button Content="Заметки" Height="40" Margin="0,0,0,8"/>
                <Button Content="НАСтр" Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#252526" Padding="10">
            <modules:ProjectsView DataContext="{Binding ProjectsVM}"/>
        </Border>

        <Border Grid.ColumnSpan="2"
                Background="#80000000"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="1000">
            <Border Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Width="600"
                    MaxHeight="700"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <views:ProjectSettingsView DataContext="{Binding SettingsVM}"/>

            </Border>
            
        </Border>
    </Grid>
</Window>
