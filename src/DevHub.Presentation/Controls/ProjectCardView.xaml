<UserControl x:Class="DevHub.Presentation.Controls.ProjectCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DevHub.Presentation.ViewModels"
             xmlns:converters="clr-namespace:DevHub.Presentation.Converters">
    <UserControl.Resources>
        <converters:BoolToStarConverter x:Key="BoolToStarConverter" />
        <converters:BoolToHideConverter x:Key="BoolToHideConverter" />
        <converters:LanguageIconConverter x:Key="LanguageIconConverter" />
        <converters:ProjectStatusColorConverter x:Key="ProjectStatusColorConverter" />
    </UserControl.Resources>

    <Border x:Name="CardBorder"
            Background="{StaticResource BgCardBrush}"
            CornerRadius="{StaticResource RadiusLg}"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource ShadowSm}"
            Cursor="Hand"
            Margin="6"
            Width="280">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect" Value="{StaticResource ShadowMd}" />
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <Border DockPanel.Dock="Right"
                        x:Name="StatusBadge"
                        Background="{Binding EffectiveStatus, Converter={StaticResource StatusBgConverter}}"
                        CornerRadius="8"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        MinWidth="55"
                        MaxWidth="70"
                        BorderThickness="1"
                        BorderBrush="{Binding EffectiveStatus, Converter={StaticResource ProjectStatusColorConverter}}">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="10"
                               Foreground="{Binding EffectiveStatus, Converter={StaticResource ProjectStatusColorConverter}}"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />
                </Border>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Language, Converter={StaticResource LanguageIconConverter}}"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding Name}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Text="{Binding Description}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       MaxHeight="40"
                       TextTrimming="CharacterEllipsis" />

            <TextBlock Grid.Row="2"
                       Text="{Binding FormattedUpdatedAt}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11"
                       Margin="0,6,0,0" />

            <ItemsControl Grid.Row="3"
                        ItemsSource="{Binding Tags}"
                        Margin="0,8,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgInputBrush}"
                                CornerRadius="{StaticResource RadiusSm}"
                                Padding="8,3"
                                Margin="0,0,4,4">
                            <TextBlock Text="{Binding}"
                                      FontSize="10"
                                      Foreground="{StaticResource TextSecondaryBrush}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="4" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Explorer"
                            Command="{Binding OpenInExplorerCommand}"
                            Style="{StaticResource BtnSecondary}"
                            Padding="10,6"
                            FontSize="11"
                            Margin="0,0,6,0" />
                    <Button Content="IDE"
                            Command="{Binding OpenInIdeCommand}"
                            Style="{StaticResource BtnSecondary}"
                            Padding="10,6"
                            FontSize="11"
                            Margin="0,0,6,0" />
                    <Button Content="Console"
                            Command="{Binding OpenConsoleCommand}"
                            Style="{StaticResource BtnSecondary}"
                            Padding="10,6"
                            FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleFavoriteCommand}"
                            Style="{StaticResource BtnIcon}"
                            ToolTip="Toggle favorite"
                            Width="28" Height="28"
                            Padding="0">
                        <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                  FontSize="14" />
                    </Button>
                    <Button Command="{Binding ToggleHiddenCommand}"
                            Style="{StaticResource BtnIcon}"
                            ToolTip="Toggle hidden"
                            Width="28" Height="28"
                            Padding="0">
                        <TextBlock Text="{Binding IsHidden, Converter={StaticResource BoolToHideConverter}}"
                                  FontSize="10"
                                  Foreground="{StaticResource TextMutedBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>