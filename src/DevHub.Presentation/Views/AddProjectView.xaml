<Window x:Class="DevHub.Presentation.Views.AddProjectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:domain="clr-namespace:DevHub.Domain.Models;assembly=DevHub.Domain"
        Title="{Binding Title}"
        Width="{Binding Width}"
        Height="{Binding Height}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Images/AppIcon.ico">
    <Grid Margin="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                <hc:TextBox Margin="0,0,0,16"
                         hc:InfoElement.Placeholder="Project name"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <TextBlock Text="Path" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DockPanel Margin="0,0,0,16">
                    <Button DockPanel.Dock="Right"
                            Content="Browse..."
                            Command="{Binding BrowsePathCommand}"
                            Margin="8,0,0,0" />
                    <hc:TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             hc:InfoElement.Placeholder="Project directory path" />
                </DockPanel>

                <TextBlock Text="Language" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding Language}"
                          Margin="0,0,0,16" />

                <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
                <hc:TextBox Text="{Binding Description}"
                         hc:InfoElement.Placeholder="Optional description"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="60"
                         Margin="0,0,0,16" />

                <!-- Edit-only fields -->
                <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <hc:TextBox Text="{Binding Notes}"
                                 hc:InfoElement.Placeholder="Project notes"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="60"
                                 Margin="0,0,0,16" />

                        <TextBlock Text="Preferred IDE" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableIdes}"
                                  SelectedItem="{Binding SelectedIde}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="Tags" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Content="+"
                                    Command="{Binding AddTagCommand}"
                                    Width="32"
                                    Margin="4,0,0,0" />
                            <hc:TextBox Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                                     hc:InfoElement.Placeholder="Type tag and press +" />
                        </DockPanel>
                        <WrapPanel Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E3F2FD"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="0,0,4,4"
                                                Cursor="Hand">
                                            <DockPanel>
                                                <TextBlock Text="{Binding}"
                                                           VerticalAlignment="Center"
                                                           Foreground="#1565C0" />
                                                <Button DockPanel.Dock="Right"
                                                        Content="×"
                                                        Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#999"
                                                        Padding="4,0"
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="12" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,8,0"
                            Padding="16,0" />
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Padding="16,0"
                            Style="{StaticResource ButtonPrimary}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
