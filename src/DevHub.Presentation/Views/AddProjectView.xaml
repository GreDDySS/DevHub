<Window x:Class="DevHub.Presentation.Views.AddProjectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{Binding Title}"
        Width="{Binding Width}"
        Height="{Binding Height}"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Images/AppIcon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource BgBaseBrush}" CornerRadius="12" Effect="{StaticResource ShadowXl}" Margin="8">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,20" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="─" Click="Minimize_Click" Style="{StaticResource WindowButton}" Width="36" Height="28" />
                    <Button Content="✕" Command="{Binding CancelCommand}" Style="{StaticResource WindowButtonClose}" Width="36" Height="28" FontSize="12" />
                </StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource TextH1}" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource SmoothScroll}">
                <StackPanel>
                    <TextBlock Text="Name" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,16" />

                    <TextBlock Text="Path" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right" Content="Browse" Command="{Binding BrowsePathCommand}" Style="{StaticResource BtnSecondary}" Margin="8,0,0,0" />
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                    </DockPanel>

                    <TextBlock Text="Language" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}" Margin="0,0,0,16" />

                    <TextBlock Text="Description" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0,0,0,16" />

                    <!-- Edit-only fields -->
                    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Notes" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Notes}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0,0,0,16" />

                            <TextBlock Text="Preferred IDE" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding AvailableIdes}" SelectedItem="{Binding SelectedIde}" DisplayMemberPath="Name" Margin="0,0,0,16" />

                            <TextBlock Text="Tags" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Content="+" Command="{Binding AddTagCommand}" Style="{StaticResource BtnSecondary}" Width="36" Margin="4,0,0,0" Padding="0" />
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                            <WrapPanel Margin="0,0,0,16">
                                <ItemsControl ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BgInputBrush}" CornerRadius="{StaticResource RadiusSm}" Padding="8,4" Margin="0,0,4,4">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                                    <Button DockPanel.Dock="Right" Content="✕" Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource BtnIcon}" Padding="4,0" Margin="4,0,0,0" FontSize="10" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#1FEF4444" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="12" Margin="0,0,0,8" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" />
                    </Border>

                    <hc:LoadingLine Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8" />
                </StackPanel>
            </ScrollViewer>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0" Padding="20,8" IsCancel="True" />
                <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource BtnPrimary}" Padding="20,8" IsDefault="True" IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
