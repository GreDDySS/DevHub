<UserControl x:Class="DevHub.Presentation.Views.LinkListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:domain="clr-namespace:DevHub.Domain.Models;assembly=DevHub.Domain">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Links"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding TotalCount, StringFormat=' ({0})'}"
                           FontSize="28"
                           Foreground="#888" />
            </StackPanel>
        </DockPanel>

        <!-- Search and Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <hc:TextBox hc:InfoElement.Placeholder="Search links..."
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        Width="300"
                        Margin="0,0,10,0" />
            <ComboBox ItemsSource="{Binding LinkTypes}"
                      SelectedItem="{Binding TypeFilter}"
                      Width="150" />
        </StackPanel>

        <!-- Hint -->
        <TextBlock Grid.Row="2"
                   Text="Press Ctrl+Shift+Y to capture URL from clipboard"
                   Foreground="#999"
                   FontSize="12"
                   Margin="0,0,0,10" />

        <!-- Empty State -->
        <StackPanel Grid.Row="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Links.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <TextBlock Text="No links yet"
                       FontSize="18"
                       Foreground="#999"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Copy a URL and press Ctrl+Shift+Y to capture it"
                       Foreground="#BBB"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- Link List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Links}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type domain:Link}">
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <DockPanel>
                                <!-- Type Badge -->
                                <Border DockPanel.Dock="Right"
                                        Background="{Binding Type, Converter={StaticResource LinkTypeToColorConverter}}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Type}"
                                               FontSize="10"
                                               Foreground="White"
                                               FontWeight="Bold" />
                                </Border>

                                <!-- Delete Button -->
                                <Button DockPanel.Dock="Right"
                                        Content="Delete"
                                        Margin="8,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding DataContext.RemoveLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}" />

                                <!-- Copy Button -->
                                <Button DockPanel.Dock="Right"
                                        Content="Copy"
                                        Margin="8,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding DataContext.CopyUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />

                                <!-- Content -->
                                <StackPanel>
                                    <TextBlock Text="{Binding Url}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Cursor="Hand" />
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#666"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding CapturedAt, StringFormat='Captured: {0:dd.MM.yyyy HH:mm}'}"
                                               Foreground="#999"
                                               FontSize="10"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading -->
        <Grid Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <hc:LoadingLine />
        </Grid>
    </Grid>
</UserControl>
