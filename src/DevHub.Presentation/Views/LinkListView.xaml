<UserControl x:Class="DevHub.Presentation.Views.LinkListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:domain="clr-namespace:DevHub.Domain.Models;assembly=DevHub.Domain"
             xmlns:attached="clr-namespace:DevHub.Presentation.Attached"
             xmlns:converters="clr-namespace:DevHub.Presentation.Converters"
             xmlns:vm="clr-namespace:DevHub.Presentation.ViewModels">
    <UserControl.Resources>
        <converters:ViewModeToIconConverter x:Key="ViewModeToIconConverter" />
        <converters:ListVisibilityConverter x:Key="ListVisibilityConverter" />
        <converters:FoldersVisibilityConverter x:Key="FoldersVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Links"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding TotalCount, StringFormat=' ({0})'}"
                           FontSize="28"
                           Foreground="#888" />
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <hc:TextBox hc:InfoElement.Placeholder="Search links..."
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        Width="300"
                        Margin="0,0,10,0" />
            <ComboBox SelectedIndex="{Binding SelectedTypeIndex}"
                      Width="150"
                      Margin="0,0,10,0">
                <ComboBoxItem Content="All types" IsSelected="True" />
                <ComboBoxItem Content="YouTube" />
                <ComboBoxItem Content="Article" />
                <ComboBoxItem Content="Repository" />
                <ComboBoxItem Content="Documentation" />
                <ComboBoxItem Content="Other" />
            </ComboBox>
            <Button Content="Reset"
                    Command="{Binding ResetFiltersCommand}"
                    Padding="10,4"
                    Margin="0,0,8,0" />
            <Button Content="{Binding ViewMode, Converter={StaticResource ViewModeToIconConverter}}"
                    Command="{Binding ToggleViewModeCommand}"
                    Padding="10,4"
                    ToolTip="Toggle view" />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="Press Ctrl+Shift+Y to capture URL from clipboard"
                   Foreground="#999"
                   FontSize="12"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Links.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <TextBlock Text="No links yet"
                       FontSize="18"
                       Foreground="#999"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Copy a URL and press Ctrl+Shift+Y to capture it"
                       Foreground="#BBB"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- List View -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ViewMode, Converter={StaticResource ListVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Links}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type domain:Link}">
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Right"
                                        Background="{Binding Type, Converter={StaticResource LinkTypeToColorConverter}}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Type}"
                                               FontSize="10"
                                               Foreground="White"
                                               FontWeight="Bold" />
                                </Border>

                                <Button DockPanel.Dock="Right"
                                        Content="Delete"
                                        Margin="8,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding DataContext.RemoveLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}" />

                                <Button DockPanel.Dock="Right"
                                        Content="Copy"
                                        Margin="8,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding DataContext.CopyUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />

                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#1565C0"
                                               Cursor="Hand"
                                               attached:MouseBehavior.LeftButtonUpCommand="{Binding DataContext.OpenInBrowserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               attached:MouseBehavior.LeftButtonUpCommandParameter="{Binding Url}" />
                                    <TextBlock Text="{Binding Url}"
                                               Foreground="#666"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CapturedAt, StringFormat='Captured: {0:dd.MM.yyyy HH:mm}'}"
                                               Foreground="#999"
                                               FontSize="10"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Folders View -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ViewMode, Converter={StaticResource FoldersVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Folders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LinkFolderViewModel}">
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,12"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Right"
                                        Background="#E3F2FD"
                                        CornerRadius="10"
                                        Padding="8,4"
                                        VerticalAlignment="Top"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Count}"
                                               Foreground="#1565C0"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding Links}" MaxHeight="200">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type domain:Link}">
                                                <DockPanel Margin="0,0,0,4">
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding Type}"
                                                               FontSize="9"
                                                               Foreground="#999"
                                                               Margin="8,0,0,0" />
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12"
                                                               Foreground="#1565C0"
                                                               Cursor="Hand"
                                                               TextTrimming="CharacterEllipsis"
                                                               attached:MouseBehavior.LeftButtonUpCommand="{Binding DataContext.OpenInBrowserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               attached:MouseBehavior.LeftButtonUpCommandParameter="{Binding Url}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="4" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <hc:LoadingLine />
        </Grid>
    </Grid>
</UserControl>
