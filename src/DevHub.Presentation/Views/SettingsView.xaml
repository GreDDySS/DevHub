<UserControl x:Class="DevHub.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:storage="clr-namespace:DevHub.Infrastructure.Storage;assembly=DevHub.Infrastructure">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,24" />

        <!-- IDE Section -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <TextBlock Text="IDE Configuration"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Auto-detect"
                                Command="{Binding AutoDetectCommand}"
                                Margin="0,0,8,0"
                                Padding="10,4" />
                        <Button Content="+"
                                Command="{Binding AddIdeCommand}"
                                Padding="10,4" />
                    </StackPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Ides}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type storage:IdeEntry}">
                            <DockPanel Margin="0,0,0,8">
                                <RadioButton DockPanel.Dock="Left"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             GroupName="DefaultIde" />
                                <Button DockPanel.Dock="Right"
                                        Content="Remove"
                                        Margin="8,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding DataContext.RemoveIdeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Path}"
                                           Foreground="#888"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No IDEs configured. Click Auto-detect or + to add."
                           Foreground="#999"
                           FontStyle="Italic"
                           Visibility="{Binding Ides.Count, Converter={StaticResource CountToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <!-- App Section -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Application"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <CheckBox Content="Start with Windows"
                          IsChecked="{Binding Settings.AutostartEnabled}"
                          Margin="0,0,0,16" />

                <TextBlock Text="On window close:"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <RadioButton Content="Exit application"
                             GroupName="CloseAction"
                             IsChecked="{Binding IsCloseExit}"
                             Margin="0,0,0,4" />

                <RadioButton Content="Minimize to tray"
                             GroupName="CloseAction"
                             IsChecked="{Binding IsCloseTray}"
                             Margin="0,0,0,4" />

                <RadioButton Content="Ask every time"
                             GroupName="CloseAction"
                             IsChecked="{Binding IsCloseAsk}" />
            </StackPanel>
        </Border>

        <!-- Error -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                   Margin="0,0,0,16" />

        <!-- Save Button -->
        <Button Grid.Row="4"
                Content="Save Settings"
                Command="{Binding SaveCommand}"
                Style="{StaticResource ButtonPrimary}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Padding="16,8" />
    </Grid>
</UserControl>
