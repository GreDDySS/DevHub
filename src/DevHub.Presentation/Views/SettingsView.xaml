<UserControl x:Class="DevHub.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,24" />

        <!-- IDE Section -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="IDE Configuration"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <!-- VS Code -->
                <TextBlock Text="VS Code" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right"
                            Content="Browse..."
                            Command="{Binding BrowseVsCodeCommand}"
                            Margin="8,0,0,0" />
                    <hc:TextBox hc:InfoElement.Placeholder="Path to Code.exe"
                                Text="{Binding Settings.VsCodePath, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <!-- Visual Studio -->
                <TextBlock Text="Visual Studio" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right"
                            Content="Browse..."
                            Command="{Binding BrowseVisualStudioCommand}"
                            Margin="8,0,0,0" />
                    <hc:TextBox hc:InfoElement.Placeholder="Path to devenv.exe"
                                Text="{Binding Settings.VisualStudioPath, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <!-- Rider -->
                <TextBlock Text="Rider" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right"
                            Content="Browse..."
                            Command="{Binding BrowseRiderCommand}"
                            Margin="8,0,0,0" />
                    <hc:TextBox hc:InfoElement.Placeholder="Path to rider64.exe"
                                Text="{Binding Settings.RiderPath, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <Button Content="Auto-detect IDEs"
                        Command="{Binding AutoDetectCommand}"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Border>

        <!-- App Section -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Application"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <CheckBox Content="Start with Windows"
                          IsChecked="{Binding Settings.AutostartEnabled}"
                          Margin="0,0,0,8" />

                <CheckBox Content="Minimize to tray"
                          IsChecked="{Binding Settings.MinimizeToTray}" />
            </StackPanel>
        </Border>

        <!-- Error -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                   Margin="0,0,0,16" />

        <!-- Save Button -->
        <Button Grid.Row="4"
                Content="Save Settings"
                Command="{Binding SaveCommand}"
                Style="{StaticResource ButtonPrimary}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Padding="16,8" />
    </Grid>
</UserControl>
