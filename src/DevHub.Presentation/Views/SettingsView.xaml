<UserControl x:Class="DevHub.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:storage="clr-namespace:DevHub.Domain.Models;assembly=DevHub.Domain">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24" />

        <!-- IDE Section -->
        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Effect="{StaticResource ShadowSm}" Margin="0,0,0,16">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <TextBlock Text="IDE Configuration" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Auto-detect" Command="{Binding AutoDetectCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0" Padding="12,8" />
                        <Button Content="+ Add IDE" Command="{Binding AddIdeCommand}" Style="{StaticResource BtnPrimary}" Padding="16,8" />
                    </StackPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Ides}" x:Name="IdeItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type storage:IdeEntry}">
                            <Border Background="{StaticResource BgInputBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                <DockPanel>
                                    <RadioButton DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center" GroupName="DefaultIde" Checked="IdeRadioButton_Checked" />
                                    <Button DockPanel.Dock="Right" Content="Remove" Style="{StaticResource BtnSecondary}" Margin="8,0,0,0" Padding="8,4" FontSize="11" Command="{Binding DataContext.RemoveIdeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No IDEs configured. Click Auto-detect or + Add IDE to get started." Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic" Visibility="{Binding Ides.Count, Converter={StaticResource CountToVisibilityConverter}}" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Application Section -->
        <Border Grid.Row="2" Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Effect="{StaticResource ShadowSm}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Application" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                <CheckBox Content="Start with Windows" IsChecked="{Binding Settings.AutostartEnabled}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

                <TextBlock Text="On window close:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10" />

                <StackPanel Margin="0,0,0,8">
                    <RadioButton Content="Exit application" GroupName="CloseAction" IsChecked="{Binding IsCloseExit}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                    <RadioButton Content="Minimize to tray" GroupName="CloseAction" IsChecked="{Binding IsCloseTray}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                    <RadioButton Content="Ask every time" GroupName="CloseAction" IsChecked="{Binding IsCloseAsk}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Error -->
        <Border Grid.Row="3" Background="#1FEF4444" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,16" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" />
        </Border>

        <!-- Save Button -->
        <Button Grid.Row="4" Content="Save Settings" Command="{Binding SaveCommand}" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left" Padding="24,12" />
    </Grid>
</UserControl>