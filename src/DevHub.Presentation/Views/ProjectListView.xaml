<UserControl x:Class="DevHub.Presentation.Views.ProjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DevHub.Presentation.ViewModels"
             xmlns:converters="clr-namespace:DevHub.Presentation.Converters"
             xmlns:attached="clr-namespace:DevHub.Presentation.Attached"
             xmlns:controls="clr-namespace:DevHub.Presentation.Controls">
    <UserControl.Resources>
        <converters:ViewModeToIconConverter x:Key="ViewModeToIconConverter" />
        <converters:TilesVisibilityConverter x:Key="TilesVisibilityConverter" />
        <converters:ListVisibilityConverter x:Key="ListVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Auto-detect" Command="{Binding AutoDetectCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,10,0" Padding="16,8" />
                <Button Content="+ Add Project" Command="{Binding AddProjectCommand}" Style="{StaticResource BtnPrimary}" Padding="20,10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Projects" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding TotalCount, StringFormat=' ({0})'}" FontSize="28" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="{StaticResource BgSurfaceBrush}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleViewModeCommand}" Style="{StaticResource BtnSecondary}" ToolTip="Toggle view" Padding="10,6">
                        <TextBlock Text="{Binding ViewMode, Converter={StaticResource ViewModeToIconConverter}}" FontSize="12" />
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Width="260" Style="{StaticResource InputBox}" Tag="Search projects..." />
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding StatusFilter}" Width="120" Margin="12,0,0,0" />
                    <CheckBox Content="Show hidden" IsChecked="{Binding ShowHidden}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding Projects.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="16" Padding="48,40" Effect="{StaticResource ShadowMd}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📂" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,20" />
                    <TextBlock Text="No projects yet" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Add your first project to get started" FontSize="14" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,28" />
                    <Button Content="+ Add Project" Command="{Binding AddProjectCommand}" Style="{StaticResource BtnPrimary}" Padding="24,12" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Visibility="{Binding ViewMode, Converter={StaticResource TilesVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Projects}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectCardViewModel}">
                        <controls:ProjectCardView attached:MouseBehavior.DoubleClickCommand="{Binding EditCommand}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Visibility="{Binding ViewMode, Converter={StaticResource ListVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectCardViewModel}">
                        <controls:ProjectListItemView attached:MouseBehavior.DoubleClickCommand="{Binding EditCommand}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#CC18181B" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Foreground="{StaticResource PrimaryBrush}" Background="{StaticResource BgInputBrush}" />
                <TextBlock Text="Loading..." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1FEF4444" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,12" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="5" VerticalAlignment="Top">
            <DockPanel>
                <TextBlock Text="⚠" FontSize="18" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>