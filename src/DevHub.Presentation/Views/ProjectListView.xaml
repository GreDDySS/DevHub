<UserControl x:Class="DevHub.Presentation.Views.ProjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:DevHub.Presentation.ViewModels"
             xmlns:converters="clr-namespace:DevHub.Presentation.Converters"
             xmlns:attached="clr-namespace:DevHub.Presentation.Attached"
             xmlns:domain="clr-namespace:DevHub.Domain.Enums;assembly=DevHub.Domain">
    <UserControl.Resources>
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <converters:BoolToStarConverter x:Key="BoolToStarConverter" />
        <converters:BoolToHideConverter x:Key="BoolToHideConverter" />
        <converters:ViewModeToIconConverter x:Key="ViewModeToIconConverter" />
        <converters:NullableStatusConverter x:Key="NullableStatusConverter" />
        <converters:TilesVisibilityConverter x:Key="TilesVisibilityConverter" />
        <converters:ListVisibilityConverter x:Key="ListVisibilityConverter" />
        <converters:LanguageIconConverter x:Key="LanguageIconConverter" />
        <converters:ProjectStatusColorConverter x:Key="ProjectStatusColorConverter" />
        <DataTemplate x:Key="StatusItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource NullableStatusConverter}}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="+ Add"
                        Command="{Binding AddProjectCommand}"
                        Style="{StaticResource ButtonPrimary}"
                        Padding="16,0"
                        Margin="0,0,8,0" />
                <Button Content="Auto-detect"
                        Command="{Binding AutoDetectCommand}"
                        Padding="16,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Projects"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding TotalCount, StringFormat=' ({0})'}"
                           FontSize="28"
                           Foreground="#888" />
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <hc:TextBox hc:InfoElement.Placeholder="Search projects..."
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Width="300"
                     Margin="0,0,10,0" />
            <ComboBox ItemsSource="{Binding Statuses}"
                      SelectedItem="{Binding StatusFilter}"
                      Width="120"
                      Margin="0,0,10,0" />
            <Button Content="{Binding ViewMode, Converter={StaticResource ViewModeToIconConverter}}"
                    Command="{Binding ToggleViewModeCommand}"
                    Margin="8,0,0,0"
                    Padding="8,4"
                    ToolTip="Toggle view" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{Binding ActiveCount, StringFormat='Active: {0}'}"
                       Foreground="#4CAF50"
                       Margin="0,0,20,0"
                       VerticalAlignment="Center" />
            <CheckBox Content="Show hidden"
                      IsChecked="{Binding ShowHidden}"
                      VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Projects.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <TextBlock Text="No projects yet"
                       FontSize="18"
                       Foreground="#999"
                       HorizontalAlignment="Center" />
            <Button Content="Add your first project"
                    Command="{Binding AddProjectCommand}"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ViewMode, Converter={StaticResource TilesVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectCardViewModel}">
                        <Border Style="{StaticResource CardStyle}" Width="280" Cursor="Hand"
                                attached:MouseBehavior.DoubleClickCommand="{Binding EditCommand}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Vertical" HorizontalAlignment="Right">
                                    <Button Content="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                            Command="{Binding ToggleFavoriteCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="16"
                                            Padding="4" />
                                    <Button Content="{Binding IsHidden, Converter={StaticResource BoolToHideConverter}}"
                                            Command="{Binding ToggleHiddenCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="10"
                                            Foreground="#999"
                                            Padding="4" />
                                </StackPanel>
                                <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Language, Converter={StaticResource LanguageIconConverter}}"
                                               FontSize="20"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Border Background="{Binding EffectiveStatus, Converter={StaticResource ProjectStatusColorConverter}}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="10"
                                                   Foreground="White"
                                                   FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="#666"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="40" />
                                <TextBlock Text="{Binding FormattedUpdatedAt}"
                                           Foreground="#999"
                                           FontSize="11"
                                           Margin="0,8,0,0" />
                                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,8,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F0F0F0"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="0,0,4,4">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="10"
                                                           Foreground="#666" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Explorer"
                                            Command="{Binding OpenInExplorerCommand}"
                                            FontSize="11"
                                            Padding="8,4"
                                            Margin="0,0,8,0" />
                                    <Button Content="IDE"
                                            Command="{Binding OpenInIdeCommand}"
                                            FontSize="11"
                                            Padding="8,4"
                                            Margin="0,0,8,0" />
                                    <Button Content="Console"
                                            Command="{Binding OpenConsoleCommand}"
                                            FontSize="11"
                                            Padding="8,4" />
                                </StackPanel>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#C62828"
                                           FontSize="11"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- List View -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ViewMode, Converter={StaticResource ListVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectCardViewModel}">
                        <Border Background="White"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,2"
                                BorderBrush="#E0E0E0"
                                BorderThickness="0,0,0,1"
                                Cursor="Hand"
                                attached:MouseBehavior.DoubleClickCommand="{Binding EditCommand}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                        Command="{Binding ToggleFavoriteCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="14"
                                        Padding="4,0" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                    <Button Content="Explorer"
                                            Command="{Binding OpenInExplorerCommand}"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="0,0,4,0" />
                                    <Button Content="IDE"
                                            Command="{Binding OpenInIdeCommand}"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="0,0,4,0" />
                                    <Button Content="Console"
                                            Command="{Binding OpenConsoleCommand}"
                                            FontSize="10"
                                            Padding="6,2" />
                                </StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Right"
                                            Background="{Binding EffectiveStatus, Converter={StaticResource ProjectStatusColorConverter}}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="9"
                                                   Foreground="White"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <Border DockPanel.Dock="Right"
                                            Background="#F0F0F0"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Language}"
                                                   FontSize="9"
                                                   Foreground="#666" />
                                    </Border>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Language, Converter={StaticResource LanguageIconConverter}}"
                                                   FontSize="14"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#999"
                                                   FontSize="11"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="300" />
                                    </StackPanel>
                                </DockPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="4" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <hc:LoadingLine />
        </Grid>

        <Border Grid.Row="4"
                Background="#FFEBEE"
                CornerRadius="8"
                Padding="16"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828" />
        </Border>
    </Grid>
</UserControl>
