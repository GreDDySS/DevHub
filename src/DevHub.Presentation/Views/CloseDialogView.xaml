<Window x:Class="DevHub.Presentation.Views.CloseDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevHub"
        Width="350"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Images/AppIcon.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="What do you want to do?"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <CheckBox Grid.Row="1"
                  x:Name="RememberChoice"
                  Content="Remember my choice"
                  Margin="0,0,0,16" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Minimize to tray"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="Minimize_Click" />
            <Button Content="Exit"
                    Width="120"
                    Click="Exit_Click" />
        </StackPanel>
    </Grid>
</Window>
