<Application x:Class="DevHub.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:DevHub.Presentation.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Effects.xaml" />
                <ResourceDictionary Source="Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ==================== CONVERTERS ==================== -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <local:InverseBoolConverter x:Key="InverseBoolConverter" />
            <local:LinkTypeToColorConverter x:Key="LinkTypeToColorConverter" />
            <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <local:NullableStatusConverter x:Key="NullableStatusConverter" />
            <local:LanguageIconConverter x:Key="LanguageIconConverter" />
            <local:ProjectStatusColorConverter x:Key="ProjectStatusColorConverter" />
            <local:StatusBackgroundConverter x:Key="StatusBgConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
