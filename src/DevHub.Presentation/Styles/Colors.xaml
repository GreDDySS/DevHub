<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== COLOR PALETTE ==================== -->
    <Color x:Key="PrimaryColor">#337A2C</Color>
    <Color x:Key="PrimaryHoverColor">#4A9C3D</Color>
    <Color x:Key="PrimaryPressedColor">#296621</Color>

    <Color x:Key="AccentColor">#19A337</Color>

    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>

    <Color x:Key="BgWindow">#09090B</Color>
    <Color x:Key="BgBase">#18181B</Color>
    <Color x:Key="BgSurface">#27272A</Color>
    <Color x:Key="BgSidebar">#0F0F11</Color>
    <Color x:Key="BgSidebarHover">#27272A</Color>
    <Color x:Key="BgSidebarActive">#8B5CF6</Color>
    <Color x:Key="BgCard">#27272A</Color>
    <Color x:Key="BgInput">#3F3F46</Color>
    <Color x:Key="BgInputFocused">#52525B</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#FAFAFA</Color>
    <Color x:Key="TextSecondary">#A1A1AA</Color>
    <Color x:Key="TextMuted">#71717A</Color>
    <Color x:Key="TextInverse">#09090B</Color>

    <!-- Borders -->
    <Color x:Key="BorderLight">#3F3F46</Color>
    <Color x:Key="BorderMedium">#52525B</Color>
    <Color x:Key="BorderFocus">#337A2C</Color>

    <!-- ==================== LIGHT THEME ==================== -->
    <Color x:Key="LightBgWindow">#FFFFFF</Color>
    <Color x:Key="LightBgBase">#F8FAFC</Color>
    <Color x:Key="LightBgSurface">#F1F5F9</Color>
    <Color x:Key="LightBgSidebar">#F1F5F9</Color>
    <Color x:Key="LightBgSidebarHover">#E2E8F0</Color>
    <Color x:Key="LightBgCard">#FFFFFF</Color>
    <Color x:Key="LightBgInput">#F1F5F9</Color>
    <Color x:Key="LightBgInputFocused">#E2E8F0</Color>

    <Color x:Key="LightTextPrimary">#1E293B</Color>
    <Color x:Key="LightTextSecondary">#475569</Color>
    <Color x:Key="LightTextMuted">#94A3B8</Color>
    <Color x:Key="LightTextInverse">#FFFFFF</Color>

    <Color x:Key="LightBorderLight">#E2E8F0</Color>
    <Color x:Key="LightBorderMedium">#CBD5E1</Color>

    <!-- ==================== BRUSHES ==================== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <SolidColorBrush x:Key="BgWindowBrush" Color="{StaticResource BgWindow}" />
    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
    <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}" />
    <SolidColorBrush x:Key="BgSidebarHoverBrush" Color="{StaticResource BgSidebarHover}" />
    <SolidColorBrush x:Key="BgSidebarActiveBrush" Color="{StaticResource BgSidebarActive}" />
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}" />
    <SolidColorBrush x:Key="BgInputFocusedBrush" Color="{StaticResource BgInputFocused}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverse}" />

<SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}" />
    <SolidColorBrush x:Key="BorderMediumBrush" Color="{StaticResource BorderMedium}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocus}" />

    <!-- Light Theme Brushes -->
    <SolidColorBrush x:Key="LightBgWindowBrush" Color="{StaticResource LightBgWindow}" />
    <SolidColorBrush x:Key="LightBgBaseBrush" Color="{StaticResource LightBgBase}" />
    <SolidColorBrush x:Key="LightBgSurfaceBrush" Color="{StaticResource LightBgSurface}" />
    <SolidColorBrush x:Key="LightBgSidebarBrush" Color="{StaticResource LightBgSidebar}" />
    <SolidColorBrush x:Key="LightBgSidebarHoverBrush" Color="{StaticResource LightBgSidebarHover}" />
    <SolidColorBrush x:Key="LightBgSidebarActiveBrush" Color="{StaticResource LightPrimaryColor}" />
    <SolidColorBrush x:Key="LightBgCardBrush" Color="{StaticResource LightBgCard}" />
    <SolidColorBrush x:Key="LightBgInputBrush" Color="{StaticResource LightBgInput}" />
    <SolidColorBrush x:Key="LightBgInputFocusedBrush" Color="{StaticResource LightBgInputFocused}" />
    <SolidColorBrush x:Key="LightBgCardHoverBrush" Color="{StaticResource LightBgSurface}" />

    <SolidColorBrush x:Key="LightTextPrimaryBrush" Color="{StaticResource LightTextPrimary}" />
    <SolidColorBrush x:Key="LightTextSecondaryBrush" Color="{StaticResource LightTextSecondary}" />
    <SolidColorBrush x:Key="LightTextMutedBrush" Color="{StaticResource LightTextMuted}" />
    <SolidColorBrush x:Key="LightTextInverseBrush" Color="{StaticResource LightTextInverse}" />

    <SolidColorBrush x:Key="LightBorderLightBrush" Color="{StaticResource LightBorderLight}" />
    <SolidColorBrush x:Key="LightBorderMediumBrush" Color="{StaticResource LightBorderMedium}" />
    <SolidColorBrush x:Key="LightBorderFocusBrush" Color="{StaticResource PrimaryColor}" />
</ResourceDictionary>
