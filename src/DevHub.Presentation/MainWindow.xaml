    </Window.Resources>

    <Border Background="{DynamicResource BgWindowBrush}"
            CornerRadius="16"
            Effect="{StaticResource ShadowLg}"
            Margin="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource BgSidebarBrush}"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowButton}" Click="Minimize_Click">
                            <Path Data="{StaticResource IconMinimize}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource WindowButton}" Click="Maximize_Click">
                            <Path Data="{StaticResource IconMaximize}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource WindowButtonClose}" Click="Close_Click">
                            <Path Data="{StaticResource IconClose}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding SidebarWidth}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource BgSidebarBrush}"
                        CornerRadius="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="8,12,8,8">
                            <DockPanel>
                                <Button x:Name="ToggleBtn"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource BtnIconNoHover}"
                                        Click="ToggleSidebar_Click"
                                        ToolTip="Toggle sidebar"
                                        Width="32" Height="32"
                                        Padding="0">
                                    <Path x:Name="ChevronPath"
                                          Data="{StaticResource IconChevron}"
                                          Fill="{StaticResource TextMutedBrush}"
                                          Width="14" Height="14"
                                          Stretch="Uniform">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="ChevronRotate" Angle="0" CenterX="7" CenterY="7" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                                <TextBlock x:Name="LogoText"
                                           Text="{Binding SidebarTitle}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="0">
                            <Button Command="{Binding GoToProjectsCommand}"
                                    Style="{StaticResource NavButton}">
                                <DockPanel>
                                    <Path Data="{StaticResource IconProjects}"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          Width="18" Height="18"
                                          Stretch="Uniform"
                                          DockPanel.Dock="Left" />
                                    <TextBlock Text="Projects"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               Visibility="{Binding SidebarTextVisibility}" />
                                </DockPanel>
                            </Button>

                            <Button Command="{Binding GoToLinksCommand}"
                                    Style="{StaticResource NavButton}">
                                <DockPanel>
                                    <Path Data="{StaticResource IconLinks}"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          Width="18" Height="18"
                                          Stretch="Uniform"
                                          DockPanel.Dock="Left"/>
                                    <TextBlock Text="Links"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               Visibility="{Binding SidebarTextVisibility}" />
                                </DockPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="4,8,4,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                      Visibility="{Binding SidebarTextVisibility}">
                                <Button Style="{StaticResource BtnIcon}"
                                        ToolTip="Toggle theme"
                                        Width="28" Height="28" Padding="0"
                                        Click="ToggleTheme_Click">
                                    <Path Data="{StaticResource IconMoon}"
                                          Fill="{StaticResource TextMutedBrush}"
                                          Width="14" Height="14"
                                          Stretch="Uniform" />
                                </Button>
                                <Button Command="{Binding OpenGitHubCommand}"
                                        Style="{StaticResource BtnIcon}"
                                        ToolTip="GitHub"
                                        Width="28" Height="28" Padding="0">
                                    <Grid>
                                        <Path Data="{StaticResource IconGitHub}"
                                              Fill="{StaticResource TextMutedBrush}"
                                              Width="14" Height="14"
                                              Stretch="Uniform" />
                                        <Ellipse Width="8" Height="8" Fill="#EF4444" 
                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="4,-2,-2,0"
                                                 Visibility="{Binding HasNewVersion, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Button>
                                <Button Command="{Binding GoToSettingsCommand}"
                                        Style="{StaticResource BtnIcon}"
                                        ToolTip="Settings"
                                        Width="28" Height="28" Padding="0">
                                    <Path Data="{StaticResource IconSettings}"
                                          Fill="{StaticResource TextMutedBrush}"
                                          Width="14" Height="14"
                                          Stretch="Uniform" />
                                </Button>
                            </StackPanel>

                            <Button Command="{Binding GoToSettingsCommand}"
                                    Style="{StaticResource BtnIcon}"
                                    ToolTip="Settings"
                                    Visibility="{Binding ShowFullLogo, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    HorizontalAlignment="Center"
                                    Width="28" Height="28" Padding="0">
                                <Path Data="{StaticResource IconSettings}"
                                      Fill="{StaticResource TextMutedBrush}"
                                      Width="16" Height="16"
                                      Stretch="Uniform" />
                            </Button>

                            <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"
                                       Visibility="{Binding ShowVersion, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{DynamicResource BgBaseBrush}"
                        CornerRadius="0,0,16,0"
                        Padding="28">
                    <ContentControl x:Name="NavigationHost" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>