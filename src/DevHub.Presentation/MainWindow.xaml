<Window x:Class="DevHub.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="{Binding Width}"
        Height="{Binding Height}"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Images/AppIcon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Geometry x:Key="IconProjects">M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z</Geometry>
        <Geometry x:Key="IconLinks">M13.07 10.93l3.96-3.96a3.25 3.25 0 00-4.6-4.6l-3.96 3.96 1.42 1.42 3.96-3.96a1.25 1.25 0 011.77 1.77l-3.96 3.96-1.42-1.42-3.96 3.96a1.25 1.25 0 01-1.77-1.77l3.96-3.96 1.42 1.42zM9.51 13.07l-3.96 3.96a1.25 1.25 0 01-1.77-1.77l3.96-3.96-1.42-1.42-3.96 3.96a3.25 3.25 0 004.6 4.6l3.96-3.96-1.41-1.41z</Geometry>
        <Geometry x:Key="IconSettings">M19.14 12.94a7.07 7.07 0 00.06-.94c0-.32-.02-.64-.07-.94l2.03-1.58a.5.5 0 00.12-.64l-1.92-3.32a.5.5 0 00-.6-.22l-2.39.96a7.04 7.04 0 00-1.62-.94l-.36-2.54a.5.5 0 00-.49-.42h-3.84a.5.5 0 00-.49.42l-.36 2.54a7.04 7.04 0 00-1.62.94l-2.39-.96a.5.5 0 00-.6.22L2.74 8.86a.5.5 0 00.12.64l2.03 1.58a7.07 7.07 0 00-.07.94c0 .32.02.64.07.94l-2.03 1.58a.5.5 0 00-.12.64l1.92 3.32c.12.22.37.29.6.22l2.39-.96c.5.38 1.04.7 1.62.94l.36 2.54c.05.24.26.42.49.42h3.84c.24 0 .44-.18.49-.42l.36-2.54a7.04 7.04 0 001.62-.94l2.39.96c.23.09.48 0 .6-.22l1.92-3.32a.5.5 0 00-.12-.64l-2.03-1.58zM12 15.6A3.6 3.6 0 1115.6 12 3.6 3.6 0 0112 15.6z</Geometry>
        <Geometry x:Key="IconChevron">M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z</Geometry>
        <Geometry x:Key="IconClose">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</Geometry>
        <Geometry x:Key="IconMaximize">M3 3v18h18V3H3zm16 16H5V5h14v14z</Geometry>
        <Geometry x:Key="IconMinimize">M3 15h18v2H3z</Geometry>
    </Window.Resources>

    <Border Background="{StaticResource BgWindowBrush}"
            CornerRadius="12"
            Effect="{StaticResource ShadowXl}"
            Margin="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgBaseBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowButton}" Click="Minimize_Click">
                            <Path Data="{StaticResource IconMinimize}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource WindowButton}" Click="Maximize_Click">
                            <Path Data="{StaticResource IconMaximize}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource WindowButtonClose}" Click="Close_Click">
                            <Path Data="{StaticResource IconClose}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                </DockPanel>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding SidebarWidth}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgSidebarBrush}"
                        CornerRadius="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <Border Grid.Row="0" Height="56" Margin="16,12,16,8">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource BtnIcon}"
                                        Click="ToggleSidebar_Click"
                                        ToolTip="Toggle sidebar">
                                    <Path Data="{StaticResource IconChevron}"
                                          Fill="{StaticResource TextMutedBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="ChevronRotate" Angle="0" CenterX="8" CenterY="8" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                                <TextBlock Text="DevHub"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="1" Margin="0,8,0,16">
                            <Button Command="{Binding GoToProjectsCommand}"
                                    Style="{StaticResource NavButton}">
                                <DockPanel>
                                    <Path Data="{StaticResource IconProjects}"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          DockPanel.Dock="Left"
                                          Margin="0,0,12,0" />
                                    <TextBlock Text="Projects"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding SidebarTextVisibility}" />
                                </DockPanel>
                            </Button>

                            <Button Command="{Binding GoToLinksCommand}"
                                    Style="{StaticResource NavButton}">
                                <DockPanel>
                                    <Path Data="{StaticResource IconLinks}"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          DockPanel.Dock="Left"
                                          Margin="0,0,12,0" />
                                    <TextBlock Text="Links"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding SidebarTextVisibility}" />
                                </DockPanel>
                            </Button>

                            <Button Command="{Binding GoToSettingsCommand}"
                                    Style="{StaticResource NavButton}">
                                <DockPanel>
                                    <Path Data="{StaticResource IconSettings}"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          DockPanel.Dock="Left"
                                          Margin="0,0,12,0" />
                                    <TextBlock Text="Settings"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding SidebarTextVisibility}" />
                                </DockPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Border Grid.Column="1"
                        Background="{StaticResource BgBaseBrush}"
                        CornerRadius="0,0,12,0"
                        Padding="24">
                    <ContentControl x:Name="NavigationHost" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
