<Window x:Class="DevHub.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{Binding Title}"
        Width="{Binding Width}"
        Height="{Binding Height}"
        WindowState="{Binding WindowState}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Images/AppIcon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#F5F5F5" Padding="10">
            <StackPanel>
                <Image Source="pack://application:,,,/Images/Logo.png"
                       Height="40"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Left" />

                <Button Content="📁 Projects"
                        Command="{Binding GoToProjectsCommand}"
                        Margin="0,0,0,5"
                        Padding="10,0"
                        HorizontalContentAlignment="Left"
                        Style="{StaticResource ButtonPrimary}" />

                <Button Content="🔗 Links"
                        Command="{Binding GoToLinksCommand}"
                        Margin="0,0,0,5"
                        Padding="10,0"
                        HorizontalContentAlignment="Left" />

                <Button Content="⚙ Settings"
                        Command="{Binding GoToSettingsCommand}"
                        Margin="0,0,0,5"
                        Padding="10,0"
                        HorizontalContentAlignment="Left" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Column="1" Padding="20">
            <ContentControl x:Name="NavigationHost" />
        </Border>
    </Grid>
</Window>
